{
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devPath": "http://localhost:3000",
    "distDir": "../frontend"
  },
  "package": {
    "productName": "Kiryana POS",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "shell": {
        "open": true
      },
      "process": {
        "relaunch": true
      }
    },
    "bundle": {
      "active": true,
      "identifier": "com.kiryana.pos",
      "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
      "resources": [],
      "windows": {
        "fullscreen": false,
        "resizable": true,
        "title": "Kiryana POS",
        "width": 1280,
        "height": 720
      }
    }
  }
}